# Copie este arquivo para .env e preencha com os valores reais antes de rodar.

# ── Banco de dados (PostgreSQL / Supabase) ─────────────────────────────
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=postgres
DB_SSLMODE=require

# ── Supabase (opcional, se for usar SDK/REST diretamente também) ──────
SUPABASE_URL=
SUPABASE_KEY=

# ── Autenticação ────────────────────────────────────────────────────────
# Gere um valor aleatório forte, ex.: openssl rand -base64 48
JWT_SECRET=

# ── Servidor ─────────────────────────────────────────────────────────────
PORT=8000
# Domínio do frontend em produção (ex.: https://meu-wms.vercel.app).
# Use "*" apenas em desenvolvimento local.
ALLOWED_ORIGIN=*
